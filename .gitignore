##Objective: Prevents sensitive files, large data files, and local environment artifacts from being committed to the repository.##

# Environment and secrets
.env
*.json              # service account keys
*.pem

# Data files (never commit raw or processed data)
data/raw/
data/processed/
*.parquet
*.csv

# Python
__pycache__/
*.pyc
*.egg-info/
.venv/
venv/

# Terraform state (contains sensitive resource info)
*.tfstate
*.tfstate.backup
.terraform/

# Airflow logs
airflow/logs/

# macOS
.DS_Store

# VS Code
.vscode/